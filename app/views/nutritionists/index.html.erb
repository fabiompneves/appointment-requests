<div class="min-h-screen bg-gray-100">
  <div class="bg-gradient-to-r from-emerald-500 to-teal-500 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Top Bar -->
      <div class="flex items-center justify-between py-5">
        <div class="flex items-center gap-3">
          <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
          <h1 class="text-2xl font-bold text-white">nutrium</h1>
        </div>
        <div>
          <%= link_to "Are you a nutrition professional? Get to know our software →", nutritionists_pending_requests_path(nutritionist_id: 1), class: "text-white hover:text-emerald-100 font-medium transition text-sm", data: { turbo: false } %>
        </div>
      </div>
    </div>
  </div>
  <!-- Search Form with lighter background -->
  <div class="bg-gradient-to-r from-emerald-400 to-teal-400 shadow-lg py-10 flex items-center justify-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4 w-full">
        <%= form_with url: nutritionists_path, method: :get, local: true do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
            <div class="md:col-span-5">
              <%= f.text_field :query, 
                  value: @query,
                  placeholder: "Name, service, course appointment...", 
                  class: "w-full px-4 py-3 bg-white border-0 rounded-lg focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-emerald-500 text-sm shadow-sm text-gray-900 placeholder-gray-500" %>
            </div>
            <div class="md:col-span-5">
              <div class="relative">
                <%= f.text_field :location, 
                    value: @location,
                    placeholder: "Location", 
                    class: "w-full px-4 py-3 pl-10 bg-white border-0 rounded-lg focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-emerald-500 text-sm shadow-sm text-gray-900 placeholder-gray-500" %>
                <svg class="absolute left-3 top-3.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
            </div>
            <div class="md:col-span-2">
              <%= f.submit "Search", class: "w-full px-6 py-3 bg-gradient-to-r from-orange-400 to-orange-500 text-white font-medium rounded-lg hover:from-orange-500 hover:to-orange-600 focus:outline-none cursor-pointer transition text-sm shadow-md" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 py-10">
    <% if @nutritionists.any? %>
      <div class="grid grid-cols-1 gap-4">
        <% @nutritionists.each do |nutritionist| %>
          <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition">
            <!-- Card Content -->
            <div class="p-10 flex flex-col gap-8">
              <div class="grid grid-cols-[80%_20%] gap-4">
                <!-- Avatar & Name -->
                <div class="flex items-start gap-4 mb-4">
                  <div class="flex-shrink-0">
                    <div class="w-16 h-16 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full flex items-center justify-center shadow-sm">
                      <span class="text-white font-bold text-xl"><%= nutritionist.name[0].upcase %></span>
                    </div>
                  </div>
                  
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">
                        ✓ FOLLOW-UP
                      </span>
                    </div>
                    <h2 class="text-lg font-bold text-gray-900"><%= nutritionist.name %></h2>
                    <p class="text-sm text-gray-500">Dietitian • #<%= nutritionist.id.to_s.rjust(5, '0') %>N</p>
                  </div>
                </div>
                <!-- Actions -->
                <div class="flex flex-col gap-3">
                  <%= link_to "Schedule appointment", 
                      new_appointment_request_path(nutritionist_id: nutritionist.id), 
                      class: "block w-full text-center px-4 py-2.5 bg-gradient-to-r from-orange-400 to-pink-400 text-white font-medium rounded-lg hover:from-orange-500 hover:to-pink-500 transition shadow-sm text-sm" %>
                  <a href="#" class="block w-full text-center px-4 py-2.5 bg-emerald-50 text-emerald-700 font-medium rounded-lg hover:bg-emerald-100 transition text-sm">
                    Website
                  </a>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 px-20">
                <!-- Location -->
                <div class="mb-4 space-y-1">
                  <div class="flex items-center text-sm text-emerald-600">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                    </svg>
                    Online Follow-up
                  </div>
                  <div class="flex items-start text-sm text-gray-600 pl-6">
                    <div>
                      Rua da Leiria<br>
                      <%= nutritionist.location %>
                    </div>
                  </div>
                </div>

                <!-- Services & Price -->
                <div class="mb-4 pb-4">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center text-sm text-gray-600">
                      <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                      First appointment ▼
                    </div>
                  </div>
                  <div class="flex items-center text-sm text-gray-700">
                    <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <% if nutritionist.services.any? %>
                      <strong>€ <%= nutritionist.services.first.price.to_i %>.00</strong>
                    <% else %>
                      <strong>€ 25.00</strong>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- No Results -->
      <div class="bg-white rounded-lg shadow-sm p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">No nutritionists found</h3>
        <p class="mt-2 text-gray-500">Try adjusting your search criteria</p>
      </div>
    <% end %>
  </div>
</div>
