#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "\n== 🚀 Setting up Appointment Requests System =="
  puts "=" * 60

  puts "\n== Checking prerequisites =="
  
  # Check Ruby version
  ruby_version = `ruby -v`.strip
  puts "✓ Ruby: #{ruby_version}"
  
  # Check for Node.js
  if system("which node > /dev/null 2>&1")
    node_version = `node -v`.strip
    npm_version = `npm -v`.strip
    puts "✓ Node.js: #{node_version}"
    puts "✓ npm: v#{npm_version}"
  else
    puts "✗ Node.js not found. Please install Node.js and npm."
    exit 1
  end

  # Check for PostgreSQL
  if system("which psql > /dev/null 2>&1") || system("which postgres > /dev/null 2>&1")
    puts "✓ PostgreSQL is available"
  else
    puts "⚠ PostgreSQL not found in PATH. Make sure it's installed and running."
  end

  puts "\n== Installing Ruby dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Installing JavaScript dependencies =="
  system! "npm install"

  puts "\n== Building JavaScript assets =="
  system! "npm run build"

  # puts "\n== Copying sample files =="
  # unless File.exist?("config/database.yml")
  #   FileUtils.cp "config/database.yml.sample", "config/database.yml"
  # end

  puts "\n== Preparing database =="
  if ARGV.include?("--reset")
    system! "bin/rails db:reset"
  else
    system! "bin/rails db:prepare"
    
    # Only seed if database is empty
    if `bin/rails runner "puts Nutritionist.count"`.strip == "0"
      puts "\n== Seeding database with sample data =="
      system! "bin/rails db:seed"
    else
      puts "✓ Database already contains data (skipping seed)"
      puts "  Run 'bin/setup --reset' to reset and re-seed the database"
    end
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Running tests to verify setup =="
  puts "\n→ Running Rails tests..."
  rails_test_result = system("bin/rails test")
  
  puts "\n→ Running Jest tests..."
  jest_test_result = system("npm test")

  puts "\n" + "=" * 60
  if rails_test_result && jest_test_result
    puts "✅ Setup completed successfully!"
    puts "=" * 60
    puts "\n📚 All tests passed! Your environment is ready."
    puts "\n🎯 Quick Start:"
    puts "  • Start development server: bin/dev"
    puts "  • Visit: http://localhost:3000"
    puts "  • View pending requests: http://localhost:3000/nutritionists/1/pending_requests"
    puts "\n📖 Documentation: README.md"
  else
    puts "⚠️  Setup completed with test failures"
    puts "=" * 60
    puts "\n⚠  Some tests failed. Please review the output above."
    puts "   You can still start the server with: bin/dev"
  end

  unless ARGV.include?("--no-server")
    puts "\n" + "=" * 60
    puts "Press ENTER to start the development server (or Ctrl+C to exit)"
    gets
    puts "\n== Starting development server =="
    puts "→ Rails server will start on http://localhost:3000"
    puts "→ Press Ctrl+C to stop"
    puts "=" * 60
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
